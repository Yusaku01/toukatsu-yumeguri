---
import type { Spa } from "../lib/types";
import { getSpaTagGroups } from "../lib/tag-groups";

type Props = {
  spa: Spa;
};

const { spa } = Astro.props;
const tagGroups = getSpaTagGroups(spa);
---

<article class="spa-card" data-spa-card={spa.id}>
  <div class="spa-card-main">
    <p class="spa-meta">
      <span>{spa.city}</span>
      {spa.area && <span>{spa.area}</span>}
      <span data-distance hidden></span>
    </p>
    <h2>{spa.name}</h2>
    <div class="spa-detail-list">
      <div class="spa-detail-row">
        <span class="spa-detail-label">住所</span>
        <address>{spa.address}</address>
      </div>
      {
        spa.notes && (
          <div class="spa-detail-row">
            <span class="spa-detail-label">メモ</span>
            <p class="spa-notes">{spa.notes}</p>
          </div>
        )
      }
      {
        tagGroups.length > 0 && (
          <div class="spa-detail-row">
            <span class="spa-detail-label">特徴</span>
            <div
              class="tag-groups"
              role="group"
              aria-label={`${spa.name}の特徴`}
            >
              {tagGroups.map((group) => (
                <div class="tag-group">
                  <span class="tag-group-label">{group.label}</span>
                  <ul class="tag-list">
                    {group.tags.map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
  <div class="spa-actions">
    <a
      class="external-link primary-link"
      href={spa.googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Google マップ
    </a>
    <a
      class="external-link"
      href={spa.officialUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      公式サイト
    </a>
  </div>
</article>

<style>
  .spa-card {
    display: grid;
    align-content: space-between;
    gap: 1rem;
    padding: 1rem;
    text-align: start;
    background: var(--color-surface-strong);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    box-shadow: 0 5px 18px rgb(45 22 14 / 7%);
  }

  .spa-card[data-selected] {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px rgb(184 42 11 / 18%);
  }

  .spa-card-main {
    min-width: 0;
  }

  .spa-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--color-brand);
  }

  .spa-meta span {
    display: inline-flex;
    align-items: center;
    min-height: 1.6rem;
    padding: 0.15rem 0.5rem;
    background: #fff3ea;
    border-radius: var(--radius-pill);
  }

  .spa-meta span[hidden] {
    display: none;
  }

  h2 {
    margin: 0;
    font-size: clamp(1rem, 2.8vw, 1.18rem);
    line-height: 1.35;
    letter-spacing: 0;
  }

  address {
    margin: 0;
    font-style: normal;
    color: var(--color-muted);
  }

  .spa-notes {
    margin: 0;
    color: var(--color-muted);
  }

  .spa-detail-list {
    display: grid;
    margin-block-start: 0.9rem;
    border-block: 1px solid var(--color-border);
  }

  .spa-detail-row {
    display: grid;
    grid-template-columns: 3.75rem minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
    padding-block: 0.72rem;
  }

  .spa-detail-row:not(:last-child) {
    border-bottom: 1px solid var(--color-border);
  }

  .spa-detail-label {
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1.5;
    color: var(--color-muted);
  }

  .tag-groups {
    display: grid;
    gap: 0.4rem;
    min-width: 0;
  }

  .tag-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    min-width: 0;
  }

  .tag-group-label {
    font-size: 0.72rem;
    font-weight: 800;
    color: var(--color-muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tag-list li {
    padding: 0.18rem 0.48rem;
    font-size: 0.78rem;
    color: var(--color-brand-dark);
    background: var(--color-paper);
    border-radius: var(--radius-pill);
  }

  .spa-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    justify-content: center;
    width: min(100%, 18.5rem);
    margin-inline: auto;
  }

  .spa-actions :global(.external-link) {
    justify-content: center;
    inline-size: 100%;
    block-size: 3.25rem;
    min-width: 0;
    min-height: 0;
    padding-block: 0;
    text-align: center;
    white-space: nowrap;
  }
</style>
