---
type Props = {
  current?: "map" | "list" | "my" | "terms";
};

const current = Astro.props.current ?? "map";
const mapPrefetch = current === "map" ? undefined : "viewport";
const mapReload = current === "map" ? undefined : true;
---

<header class="site-header" transition:name="site-header">
  <a
    class="brand-pill"
    href="/"
    aria-label="東葛湯めぐりマップ ホーム"
    data-astro-prefetch={mapPrefetch}
    data-astro-reload={mapReload}
  >
    <span class="brand-mark" aria-hidden="true">
      <img src="/pin.svg" alt="" width="30" height="48" />
    </span>
    <span class="brand-title">東葛湯めぐりマップ</span>
  </a>
  <details class="nav-menu">
    <summary>MENU</summary>
    <nav aria-label="主要ページ">
      <a
        href="/"
        aria-current={current === "map" ? "page" : undefined}
        data-astro-prefetch={mapPrefetch}
        data-astro-reload={mapReload}>地図</a
      >
      <a href="/list/" aria-current={current === "list" ? "page" : undefined}
        >一覧</a
      >
      <a href="/my/" aria-current={current === "my" ? "page" : undefined}
        >マイページ</a
      >
      <a href="/terms/" aria-current={current === "terms" ? "page" : undefined}
        >利用規約</a
      >
    </nav>
  </details>
</header>
