---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFeatureFilterCounts } from "../lib/filters";
import { getCityCounts, getSpas } from "../lib/spas";

const spas = await getSpas();
const cityCounts = getCityCounts(spas);
const featureCounts = getFeatureFilterCounts(spas);
const totalSpaCount = spas.length;
const pageTitle = "東葛の温浴施設を地図で探す";
const pageDescription = `松戸・柏・流山を中心に、東葛周辺の温浴施設${totalSpaCount}件を地図と特徴フィルターで探せる湯めぐりマップです。`;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: `${pageTitle} | 東葛湯めぐりマップ`,
  description: pageDescription,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: totalSpaCount,
    itemListElement: spas.map((spa, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "LocalBusiness",
        name: spa.name,
        address: spa.address,
        url: spa.officialUrl,
        hasMap: spa.googleMapsUrl,
      },
    })),
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  bodyClass="prototype-map-page"
  canonicalPath="/"
  jsonLd={structuredData}
>
  <fragment slot="head">
    <link rel="preconnect" href="https://tile.openstreetmap.jp" />
    <link
      rel="preload"
      href="https://tile.openstreetmap.jp/styles/osm-bright-ja/13/7280/3221.png"
      as="image"
      type="image/png"
      fetchpriority="high"
      media="(max-width: 900px)"
    />
    <link
      rel="preload"
      href="https://tile.openstreetmap.jp/styles/osm-bright-ja/13/7281/3221.png"
      as="image"
      type="image/png"
      fetchpriority="high"
      media="(max-width: 900px)"
    />
  </fragment>
  <main id="content" class="prototype-map" tabindex="-1">
    <h1 class="visually-hidden">{pageTitle}</h1>
    <p id="prototype-map-instructions" class="visually-hidden">
      地域や特徴のボタンで温浴施設を絞り込み、地図上のピンを選ぶと施設情報を確認できます。
    </p>
    <div
      id="prototype-map-canvas"
      role="region"
      aria-label="温浴施設の地図"
      aria-describedby="prototype-map-instructions"
      data-spas={JSON.stringify(spas)}
    >
    </div>

    <header class="prototype-header" aria-label="サイトナビゲーション">
      <a class="prototype-brand" href="/" aria-label="東葛湯めぐりマップ">
        <span class="prototype-brand-pin-shell" aria-hidden="true">
          <span class="prototype-brand-pin"></span>
        </span>
        <span>東葛湯めぐりマップ</span>
      </a>
      <details class="prototype-menu">
        <summary>
          <span class="prototype-icon prototype-icon--menu" aria-hidden="true"
          ></span>
          <span>MENU</span>
        </summary>
        <nav aria-label="サイトメニュー">
          <a href="/">現在の地図</a>
          <a href="/list/">一覧</a>
          <a href="/terms/">利用規約</a>
        </nav>
      </details>
    </header>

    <search class="prototype-filters" aria-label="温浴施設の絞り込み">
      <div
        class="prototype-chip-row"
        role="group"
        aria-label="地域で絞り込み"
        data-prototype-city-list
      >
        <button
          type="button"
          data-prototype-city="all"
          aria-pressed="true"
          aria-label={`すべての施設を表示。${totalSpaCount}件`}
        >
          <span>すべて</span>
          <span class="prototype-count">{totalSpaCount}</span>
        </button>
        {
          cityCounts.map(({ city, count }) => (
            <button
              type="button"
              data-prototype-city={city}
              aria-pressed="false"
              aria-label={`${city}の施設に絞り込む。${count}件`}
            >
              <span>{city}</span>
              <span class="prototype-count">{count}</span>
            </button>
          ))
        }
      </div>

      <div class="prototype-filter-line">
        <div
          class="prototype-chip-row"
          role="group"
          aria-label="特徴で絞り込み"
          data-prototype-feature-list
        >
          {
            featureCounts.map(({ id, label, count }) => (
              <button
                type="button"
                data-prototype-feature={id}
                aria-pressed="false"
                aria-label={`${label}で絞り込む。${count}件`}
              >
                <span
                  class:list={["prototype-icon", `prototype-icon--${id}`]}
                  aria-hidden="true"
                />
                <span>{label}</span>
              </button>
            ))
          }
        </div>
      </div>

      <div class="prototype-filter-status-row">
        <div
          class="prototype-status-copy"
          aria-live="polite"
          aria-atomic="true"
        >
          <p class="prototype-status" data-prototype-status>
            {totalSpaCount}件
          </p>
        </div>
        <button
          class="prototype-clear"
          type="button"
          data-prototype-clear
          hidden
        >
          <span
            class="prototype-icon prototype-icon--refresh"
            aria-hidden="true"></span>
          <span>クリア</span>
        </button>
      </div>
    </search>

    <aside
      class="prototype-place-sheet"
      aria-label="選択した温浴施設"
      aria-hidden="true"
      data-prototype-panel
    >
      <button
        class="prototype-grip"
        type="button"
        data-prototype-grip
        aria-label="施設カードをたたむ"
      >
        <span aria-hidden="true"></span>
      </button>
      <div class="prototype-card-host" data-prototype-card></div>
    </aside>
  </main>
  <script>
    import "../scripts/map";
  </script>
</BaseLayout>

<style>
  :global(body.prototype-map-page) {
    overflow: hidden;
    background: #fffaf7;
  }

  .prototype-map {
    --prototype-top-panel-height: clamp(13.25rem, 26svh, 13.55rem);
    --prototype-ink: #3e2013;
    --prototype-muted: #7d6559;
    --prototype-line: rgb(80 45 28 / 13%);
    --prototype-paper: rgb(255 251 246 / 96%);
    --prototype-paper-solid: #fffaf7;
    --prototype-brand: #c82006;
    --prototype-brand-pressed: #a91b05;
    --prototype-brand-dark: #451406;
    --prototype-blue: #0f6ea6;
    --prototype-blue-soft: #e6f5fb;
    --prototype-surface-hover: #fff6ef;
    --prototype-surface-pressed: #f5e8dd;
    --prototype-tag-surface: #fff3ea;
    --prototype-ease: cubic-bezier(0.2, 0, 0, 1);
    position: relative;
    inline-size: min(100dvw, 520px);
    max-inline-size: 520px;
    block-size: 100svh;
    min-block-size: 0;
    margin-inline: auto;
    overflow: hidden;
    color: var(--prototype-ink);
    background: #fffaf7;
  }

  .prototype-map::before {
    position: absolute;
    z-index: 760;
    inset-block-start: 0;
    inset-inline: 0;
    block-size: var(--prototype-top-panel-height);
    pointer-events: none;
    content: "";
    background:
      linear-gradient(180deg, rgb(255 251 246 / 98%), rgb(255 251 246 / 94%)),
      #fffaf7;
  }

  #prototype-map-canvas {
    inline-size: 100%;
    block-size: 100%;
    background: #eef0ec;
  }

  .prototype-map :global(.prototype-leaflet-pin) {
    transform-origin: 50% 100%;
    scale: 1;
    translate: 0 0;
    transition:
      scale 180ms var(--prototype-ease),
      translate 180ms var(--prototype-ease),
      filter 180ms var(--prototype-ease);
  }

  .prototype-map :global(.prototype-leaflet-pin.is-selected) {
    filter: saturate(1.12) contrast(1.04);
    scale: 1.12;
    translate: 0 -0.2rem;
  }

  .prototype-header {
    position: absolute;
    z-index: 900;
    inset-block-start: max(1.35rem, env(safe-area-inset-top));
    inset-inline: 0.86rem;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    pointer-events: none;
  }

  .prototype-brand,
  .prototype-menu summary {
    min-block-size: 2.7rem;
    border-radius: 999px;
    backdrop-filter: blur(14px);
    pointer-events: auto;
  }

  .prototype-brand {
    display: inline-flex;
    gap: 0.52rem;
    align-items: center;
    max-inline-size: calc(100% - 6.6rem);
    padding: 0.48rem 0.82rem 0.48rem 0.54rem;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--prototype-ink);
    text-decoration: none;
    background: var(--prototype-paper);
    border: 1px solid var(--prototype-line);
    transition:
      background-color 180ms var(--prototype-ease),
      border-color 180ms var(--prototype-ease),
      transform 180ms var(--prototype-ease);
  }

  .prototype-brand:hover {
    background: var(--prototype-surface-hover);
    border-color: rgb(80 45 28 / 22%);
    transform: translateY(-1px);
  }

  .prototype-brand:active {
    background: var(--prototype-surface-pressed);
    border-color: rgb(80 45 28 / 26%);
    transform: translateY(1px);
  }

  .prototype-brand-pin-shell {
    display: inline-grid;
    flex: 0 0 auto;
    inline-size: 1.74rem;
    block-size: 1.74rem;
    place-items: center;
  }

  .prototype-brand-pin {
    display: block;
    color: var(--prototype-brand);
    inline-size: 1.15rem;
    block-size: 1.15rem;
    background: currentColor;
    -webkit-mask: url("/onsen.svg") center / contain no-repeat;
    mask: url("/onsen.svg") center / contain no-repeat;
  }

  .prototype-brand span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .prototype-menu {
    position: relative;
    pointer-events: auto;
  }

  .prototype-menu summary {
    display: inline-flex;
    gap: 0.42rem;
    align-items: center;
    padding: 0.58rem 0.76rem;
    font-size: 0.95rem;
    font-weight: 850;
    line-height: 1;
    color: var(--prototype-ink);
    list-style: none;
    cursor: pointer;
    background: var(--prototype-paper);
    border: 1px solid var(--prototype-line);
    transition:
      background-color 180ms var(--prototype-ease),
      border-color 180ms var(--prototype-ease),
      transform 180ms var(--prototype-ease);
  }

  .prototype-menu summary:hover,
  .prototype-menu[open] summary {
    background: var(--prototype-surface-hover);
    border-color: rgb(80 45 28 / 22%);
    transform: translateY(-1px);
  }

  .prototype-menu summary:active {
    background: var(--prototype-surface-pressed);
    border-color: rgb(80 45 28 / 26%);
    transform: translateY(1px);
  }

  .prototype-menu summary::-webkit-details-marker {
    display: none;
  }

  .prototype-menu nav {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline-end: 0;
    display: grid;
    inline-size: max-content;
    min-inline-size: 8.5rem;
    padding: 0.45rem;
    background: var(--prototype-paper-solid);
    border: 1px solid var(--prototype-line);
    border-radius: 0.85rem;
  }

  .prototype-menu[open] nav {
    animation: prototype-menu-reveal 180ms var(--prototype-ease) both;
  }

  .prototype-menu a {
    padding: 0.55rem 0.7rem;
    font-weight: 800;
    color: inherit;
    text-decoration: none;
    border-radius: 0.55rem;
  }

  .prototype-menu a:hover {
    background: var(--prototype-surface-pressed);
  }

  @keyframes prototype-menu-reveal {
    from {
      opacity: 0;
      transform: translateY(-0.28rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .prototype-filters {
    position: absolute;
    z-index: 820;
    inset-block-start: 5rem;
    inset-inline: 0.86rem 0;
    display: grid;
    gap: 0.54rem;
    pointer-events: none;
  }

  .prototype-chip-row {
    display: flex;
    gap: 0.36rem;
    align-items: center;
    overflow-x: auto;
    padding-block: 0.38rem;
    margin-block: -0.38rem;
    scroll-padding-inline: 1rem;
    scrollbar-width: none;
    pointer-events: auto;
  }

  .prototype-chip-row::-webkit-scrollbar {
    display: none;
  }

  .prototype-chip-row button,
  .prototype-clear {
    display: inline-flex;
    flex: 0 0 auto;
    gap: 0.38rem;
    align-items: center;
    justify-content: center;
    min-block-size: 2.25rem;
    padding: 0.36rem 0.58rem;
    margin: 0;
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1;
    color: var(--prototype-ink);
    white-space: nowrap;
    background: var(--prototype-paper);
    border: 1px solid var(--prototype-line);
    border-radius: 999px;
    backdrop-filter: blur(13px);
    transition:
      background-color 180ms var(--prototype-ease),
      border-color 180ms var(--prototype-ease),
      color 180ms var(--prototype-ease),
      transform 180ms var(--prototype-ease);
  }

  .prototype-chip-row button:hover:not([aria-pressed="true"]),
  .prototype-clear:hover {
    color: var(--prototype-ink);
    background: var(--prototype-surface-hover);
    border-color: rgb(80 45 28 / 22%);
  }

  .prototype-chip-row button:active:not([aria-pressed="true"]),
  .prototype-clear:active {
    color: var(--prototype-ink);
    background: var(--prototype-surface-pressed);
    border-color: rgb(80 45 28 / 26%);
    transform: translateY(1px);
  }

  .prototype-chip-row button[aria-pressed="true"] {
    color: #fff;
    background:
      linear-gradient(135deg, rgb(255 132 82 / 24%), transparent 54%),
      var(--prototype-brand);
    border-color: var(--prototype-brand);
  }

  .prototype-chip-row button[aria-pressed="true"]:hover,
  .prototype-chip-row button[aria-pressed="true"]:active {
    color: #fff;
    background:
      linear-gradient(135deg, rgb(255 128 84 / 18%), transparent 54%),
      var(--prototype-brand-pressed);
    border-color: var(--prototype-brand-pressed);
  }

  .prototype-chip-row button[aria-pressed="true"]:active {
    transform: translateY(1px);
  }

  [data-prototype-feature-list] {
    gap: 0.3rem;
  }

  [data-prototype-feature-list] button {
    gap: 0.28rem;
    min-block-size: 1.94rem;
    padding: 0.28rem 0.48rem;
    font-size: 0.67rem;
    font-weight: 800;
    color: color-mix(in oklab, var(--prototype-ink), transparent 12%);
    background: rgb(255 251 246 / 58%);
    border-color: rgb(80 45 28 / 9%);
    backdrop-filter: blur(8px);
  }

  [data-prototype-feature-list] button:hover:not([aria-pressed="true"]) {
    color: var(--prototype-ink);
    background: rgb(255 246 239 / 78%);
    border-color: rgb(80 45 28 / 16%);
  }

  [data-prototype-feature-list] button[aria-pressed="true"] {
    color: var(--prototype-brand-dark);
    background: #fff0e6;
    border-color: rgb(200 32 6 / 28%);
  }

  [data-prototype-feature-list] button[aria-pressed="true"]:hover,
  [data-prototype-feature-list] button[aria-pressed="true"]:active {
    color: var(--prototype-brand-dark);
    background: #ffe7d8;
    border-color: rgb(200 32 6 / 36%);
  }

  .prototype-count {
    display: inline-grid;
    inline-size: 1.36rem;
    block-size: 1.36rem;
    padding: 0;
    place-items: center;
    aspect-ratio: 1;
    font-size: 0.72em;
    line-height: 1;
    color: color-mix(in oklab, currentColor, transparent 22%);
    background: rgb(80 45 28 / 6%);
    border-radius: 50%;
    text-box: trim-both cap alphabetic;
  }

  .prototype-chip-row button[aria-pressed="true"] .prototype-count {
    color: #fff;
    background: rgb(69 20 6 / 20%);
  }

  .prototype-filter-line,
  .prototype-filter-status-row {
    min-inline-size: 0;
    padding-inline-end: 1rem;
  }

  .prototype-filter-status-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
    min-block-size: 2.25rem;
  }

  .prototype-status-copy {
    display: grid;
    gap: 0.04rem;
    min-inline-size: 0;
  }

  .prototype-status {
    margin: 0;
    font-size: 0.86rem;
    font-weight: 850;
    line-height: 1.35;
    color: var(--prototype-ink);
    white-space: nowrap;
  }

  .prototype-chip-row .prototype-icon,
  .prototype-clear .prototype-icon {
    inline-size: 0.92rem;
    block-size: 0.92rem;
  }

  [data-prototype-feature-list] .prototype-icon {
    inline-size: 0.82rem;
    block-size: 0.82rem;
  }

  .prototype-clear {
    min-inline-size: 4.85rem;
    color: var(--prototype-muted);
    background: transparent;
    border-color: transparent;
    backdrop-filter: none;
    pointer-events: auto;
  }

  .prototype-clear:hover {
    color: var(--prototype-brand-dark);
    background: rgb(255 243 234 / 72%);
    border-color: transparent;
  }

  .prototype-clear:active {
    color: var(--prototype-brand-dark);
    background: rgb(245 232 221 / 74%);
    border-color: transparent;
  }

  .prototype-clear[hidden] {
    visibility: hidden;
    pointer-events: none;
  }

  :global(.prototype-icon) {
    display: inline-block;
    inline-size: 1.02rem;
    block-size: 1.02rem;
    flex: 0 0 auto;
    background: currentColor;
    -webkit-mask: var(--prototype-icon-url) center / contain no-repeat;
    mask: var(--prototype-icon-url) center / contain no-repeat;
  }

  :global(.prototype-icon--menu) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/menu.svg");
  }

  :global(.prototype-icon--sauna) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/flame.svg");
  }

  :global(.prototype-icon--onsen) {
    --prototype-icon-url: url("/onsen.svg");
  }

  :global(.prototype-icon--bath) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/droplets.svg");
  }

  :global(.prototype-icon--ganbanyoku) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/layers-2.svg");
  }

  :global(.prototype-icon--food) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/utensils.svg");
  }

  :global(.prototype-icon--station) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/train-front.svg");
  }

  :global(.prototype-icon--refresh) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/rotate-cw.svg");
  }

  :global(.prototype-icon--map-pin) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/map-pin.svg");
  }

  :global(.prototype-icon--map) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/map.svg");
  }

  :global(.prototype-icon--bus) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/bus-front.svg");
  }

  :global(.prototype-icon--external) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/external-link.svg");
  }

  :global(.prototype-icon--chevron) {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/chevron-right.svg");
  }

  .prototype-place-sheet {
    position: absolute;
    z-index: 880;
    inset-inline: 0;
    inset-block-end: env(safe-area-inset-bottom);
    display: grid;
    grid-template-rows: auto auto;
    align-content: start;
    block-size: auto;
    max-block-size: min(86svh, calc(100svh - 1rem));
    padding: 0 0.84rem 1rem;
    background: var(--prototype-paper-solid);
    border: 1px solid rgb(80 45 28 / 10%);
    border-block-end: 0;
    border-start-start-radius: 1.52rem;
    border-start-end-radius: 1.52rem;
    translate: 0 calc(100% - 0.3rem);
    transition: translate 240ms var(--prototype-ease);
  }

  .prototype-place-sheet:not(.has-selection) {
    visibility: hidden;
    pointer-events: none;
    translate: 0 100%;
  }

  .prototype-place-sheet.is-open {
    translate: 0 0;
  }

  .prototype-place-sheet.is-dragging {
    transition: none;
  }

  .prototype-grip {
    touch-action: none;
    display: grid;
    min-block-size: 1.85rem;
    padding: 0;
    place-items: center;
    background: transparent;
    border: 0;
  }

  .prototype-grip span {
    display: block;
    inline-size: 2.15rem;
    block-size: 0.24rem;
    background: rgb(80 45 28 / 46%);
    border-radius: 999px;
  }

  .prototype-card-host {
    inline-size: 100%;
    min-inline-size: 0;
    min-block-size: 0;
    container: inline-size / place-card;
  }

  :global(.prototype-selected-card) {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-content: start;
    inline-size: 100%;
    max-inline-size: 100%;
    min-inline-size: 0;
    block-size: auto;
  }

  :global(.prototype-place-body) {
    display: grid;
    gap: 0.82rem;
    align-content: start;
    inline-size: 100%;
    max-inline-size: 100%;
    min-inline-size: 0;
  }

  :global(.prototype-place-title) {
    display: flex;
    gap: 0.42rem;
    align-items: center;
    margin: 0;
    font-size: clamp(1.22rem, 4.2cqi, 1.42rem);
    font-weight: 900;
    line-height: 1.32;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  :global(.prototype-place-detail-list) {
    display: grid;
    --prototype-dot-divider: radial-gradient(
      circle,
      rgb(80 45 28 / 18%) 0 1.2px,
      transparent 1.35px
    );
    background:
      var(--prototype-dot-divider) left top / 0.48rem 0.25rem repeat-x,
      var(--prototype-dot-divider) left bottom / 0.48rem 0.25rem repeat-x;
  }

  :global(.prototype-place-detail-row) {
    position: relative;
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 0.68rem;
    align-items: center;
    min-inline-size: 0;
    padding-block: 0.74rem;
  }

  :global(.prototype-place-detail-row:not(:last-child))::after {
    position: absolute;
    inset-inline: 0;
    inset-block-end: -0.125rem;
