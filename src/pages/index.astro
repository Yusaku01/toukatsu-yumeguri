---
import SiteHeader from "../components/SiteHeader.astro";
import SpaCard from "../components/SpaCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCities, getSpas } from "../lib/spas";

const spas = await getSpas();
const cities = getCities(spas);
---

<BaseLayout bodyClass="map-page">
  <fragment slot="head">
    <link rel="preconnect" href="https://tile.openstreetmap.org" />
  </fragment>
  <SiteHeader current="map" />
  <main
    id="content"
    class="map-shell"
    tabindex="-1"
    transition:name="page-content"
  >
    <section class="map-stage" aria-label="温浴施設の地図">
      <div id="map" class="map-canvas" data-spas={JSON.stringify(spas)}></div>
      <search class="map-search" aria-label="温浴施設の絞り込み">
        <div class="city-filter" aria-label="市区町村で絞り込み">
          <button type="button" data-city-filter="all" aria-pressed="true"
            >すべて</button
          >
          {
            cities.map((city) => (
              <button
                type="button"
                data-city-filter={city}
                aria-pressed="false"
              >
                {city}
              </button>
            ))
          }
        </div>
      </search>
      <button
        class="locate-button"
        type="button"
        data-locate
        aria-label="現在地を表示"
      >
        <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 2v3M12 19v3M2 12h3M19 12h3"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
          <circle cx="12" cy="12" r="5" stroke="currentColor" stroke-width="2"
          ></circle>
        </svg>
      </button>
    </section>
    <aside
      id="map-panel"
      class="map-panel"
      aria-labelledby="panel-title"
      aria-expanded="false"
    >
      <button
        class="panel-grip"
        type="button"
        data-panel-grip
        aria-controls="map-panel"
        aria-label="施設一覧パネルを広げる"
      >
        <span aria-hidden="true"></span>
      </button>
      <div class="panel-head">
        <div>
          <p class="eyebrow">温浴施設</p>
          <h1 id="panel-title">今日行きたい湯を探す</h1>
        </div>
        <span class="count-badge" data-visible-count>{spas.length}件</span>
      </div>
      <div class="spa-list" data-spa-list>
        {spas.map((spa) => <SpaCard spa={spa} compact />)}
      </div>
    </aside>
  </main>
  <script>
    import "../scripts/map";
  </script>
  <script>
    const mobileQuery = window.matchMedia("(max-width: 900px)");

    const collapsedHeight = 44;
    const expandedHeight = 82;
    const minimumHeight = 36;

    const initPanelSheet = () => {
      const panel = document.querySelector<HTMLElement>(".map-panel");
      const shell = document.querySelector<HTMLElement>(".map-shell");
      const grip =
        document.querySelector<HTMLButtonElement>("[data-panel-grip]");
      if (!panel || !shell || !grip || panel.dataset.sheetReady === "true") {
        return;
      }

      panel.dataset.sheetReady = "true";

      let panelHeight = collapsedHeight;
      let startY = 0;
      let startHeight = collapsedHeight;
      let ignoreNextClick = false;

      const updatePanelHeight = (clientY: number) => {
        const delta = startY - clientY;
        if (Math.abs(delta) > 6) {
          ignoreNextClick = true;
        }

        setPanelHeight(startHeight + (delta / window.innerHeight) * 100);
      };

      const setPanelHeight = (height: number) => {
        const clampedHeight = Math.min(
          expandedHeight,
          Math.max(minimumHeight, height),
        );

        panelHeight = clampedHeight;
        shell.style.setProperty("--mobile-panel-height", `${clampedHeight}svh`);
        panel.setAttribute(
          "aria-expanded",
          clampedHeight > collapsedHeight ? "true" : "false",
        );
        grip.setAttribute(
          "aria-label",
          clampedHeight > collapsedHeight
            ? "施設一覧パネルをたたむ"
            : "施設一覧パネルを広げる",
        );
      };

      const snapPanelHeight = () => {
        setPanelHeight(panelHeight >= 60 ? expandedHeight : collapsedHeight);
        panel.classList.remove("is-dragging");
      };

      const handlePointerMove = (event: PointerEvent) => {
        if (!mobileQuery.matches) return;
        updatePanelHeight(event.clientY);
      };

      const handleTouchMove = (event: TouchEvent) => {
        if (!mobileQuery.matches || event.touches.length === 0) return;
        if (event.cancelable) event.preventDefault();
        updatePanelHeight(event.touches[0].clientY);
      };

      const startDrag = (clientY: number) => {
        startY = clientY;
        startHeight = panelHeight;
        panel.classList.add("is-dragging");
      };

      const stopDrag = () => {
        window.removeEventListener("pointermove", handlePointerMove);
        window.removeEventListener("touchmove", handleTouchMove);
        snapPanelHeight();
      };

      grip.addEventListener("pointerdown", (event) => {
        if (!mobileQuery.matches) return;
        if (event.pointerType === "touch") return;

        startDrag(event.clientY);
        grip.setPointerCapture(event.pointerId);

        window.addEventListener("pointermove", handlePointerMove);
        window.addEventListener("pointerup", stopDrag, { once: true });
        window.addEventListener("pointercancel", stopDrag, { once: true });
      });

      grip.addEventListener(
        "touchstart",
        (event) => {
          if (!mobileQuery.matches || event.touches.length === 0) return;
          if (event.cancelable) event.preventDefault();

          startDrag(event.touches[0].clientY);
          window.addEventListener("touchmove", handleTouchMove, {
            passive: false,
          });
          window.addEventListener("touchend", stopDrag, { once: true });
          window.addEventListener("touchcancel", stopDrag, { once: true });
        },
        { passive: false },
      );

      grip.addEventListener("click", () => {
        if (!mobileQuery.matches) return;

        if (ignoreNextClick) {
          ignoreNextClick = false;
          return;
        }

        setPanelHeight(
          panelHeight > collapsedHeight ? collapsedHeight : expandedHeight,
        );
      });

      mobileQuery.addEventListener("change", () => {
        if (mobileQuery.matches) {
          setPanelHeight(collapsedHeight);
          return;
        }

        shell.style.removeProperty("--mobile-panel-height");
        panel.classList.remove("is-dragging");
        panel.setAttribute("aria-expanded", "false");
      });
    };

    document.addEventListener("astro:page-load", initPanelSheet);
    initPanelSheet();
  </script>
</BaseLayout>

<style>
  .map-shell {
    --mobile-panel-height: 44svh;
    --map-control-bottom: calc(1rem + var(--safe-bottom));
    --map-control-gap: 2rem;
    --map-zoom-height: 4.25rem;

    position: relative;
    display: grid;
    grid-template-columns: minmax(22rem, 28rem) 1fr;
    width: 100vw;
    height: 100vh;
    min-height: 560px;
  }

  .map-stage {
    position: relative;
    grid-column: 1 / -1;
    grid-row: 1;
    min-width: 0;
    min-height: 0;
  }

  .map-canvas {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(120deg, rgb(112 200 215 / 16%), transparent 48%), #dce8e4;
  }

  .map-panel {
    position: relative;
    z-index: 500;
    grid-column: 1;
    grid-row: 1;
    align-self: stretch;
    width: min(28rem, calc(100vw - 1.5rem));
    max-height: calc(100vh - 7rem);
    margin: 5.6rem 0.75rem 0.75rem;
    overflow: hidden;
    background: rgb(255 250 244 / 94%);
    border: 1px solid rgb(64 19 6 / 12%);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    backdrop-filter: blur(14px);
  }

  .panel-head {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.1rem 1rem 0.85rem;
    border-bottom: 1px solid var(--color-border);
  }

  .eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.35;
    color: var(--color-brand);
  }

  h1 {
    margin: 0;
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .count-badge {
    flex: 0 0 auto;
    padding: 0.25rem 0.55rem;
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--color-surface-strong);
    background: var(--color-brand);
    border-radius: var(--radius-pill);
  }

  .location-status {
    min-height: 2rem;
    padding: 0.55rem 1rem;
    margin: 0;
    font-size: 0.88rem;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .spa-list {
    display: grid;
    gap: 0.75rem;
    max-height: calc(100vh - 15rem);
    padding: 0.75rem;
    overflow: auto;
  }

  .panel-grip {
    display: none;
  }

  .map-search {
    position: fixed;
    z-index: 700;
    inset-block-start: 0.8rem;
    inset-inline: 19rem 8rem;
    pointer-events: none;
  }

  .city-filter {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    padding-block: 0.15rem;
    overflow-x: auto;
    pointer-events: auto;
    scrollbar-width: none;
  }

  .city-filter::-webkit-scrollbar {
    display: none;
  }

  .city-filter button,
  .locate-button {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    min-height: 2.7rem;
    padding: 0.55rem 0.85rem;
    font-weight: 800;
    color: var(--color-brand-dark);
    white-space: nowrap;
    background: rgb(255 250 244 / 94%);
    border: 1px solid rgb(64 19 6 / 12%);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-chip);
    backdrop-filter: blur(12px);
  }

  .city-filter button[aria-pressed="true"],
  .locate-button:hover {
    color: var(--color-surface-strong);
    background: var(--color-brand);
    border-color: var(--color-brand);
  }

  .locate-button {
    position: fixed;
    z-index: 720;
    justify-content: center;
    width: 32px;
    min-height: 32px;
    height: 32px;
    padding-inline: 0;
    color: #000000;
    background: #fff;
    border-radius: 0;
    border: 2px solid rgba(0, 0, 0, 0.2);
    inset-block-end: calc(
      var(--map-control-bottom) + var(--map-zoom-height) +
        var(--map-control-gap)
    );
    inset-inline-end: 1.3rem;
  }

  .locate-button:hover {
    color: var(--color-brand-dark);
    background: #fff;
    border-color: rgb(64 19 6 / 12%);
  }

  .map-stage :global(.leaflet-bottom.leaflet-right) {
    margin-block-end: var(--map-control-bottom);
    margin-inline-end: 0.6rem;
  }

  .locate-button:disabled {
    cursor: progress;
    opacity: 0.72;
  }

  @media (max-width: 900px) {
    .map-shell {
      --map-control-bottom: calc(
        var(--mobile-panel-height) + 0.7rem + var(--safe-bottom)
      );

      display: block;
      min-height: 100svh;
    }

    .map-stage,
    .map-canvas {
      height: 100svh;
    }

    .map-search {
      inset-block-start: 4.35rem;
      inset-inline: 0.75rem 0;
    }

    .map-panel {
      position: fixed;
      z-index: 900;
      inset-inline: 0;
      inset-block-end: var(--safe-bottom);
      width: auto;
      height: var(--mobile-panel-height);
      max-height: calc(86svh - var(--safe-bottom));
      margin: 0;
      border-inline: 0;
      border-end-end-radius: 0;
      border-end-start-radius: 0;
      transition: height 180ms ease;
    }

    .spa-list {
      max-height: calc(var(--mobile-panel-height) - 10.25rem);
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
    }

    .panel-grip {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 2.5rem;
      padding: 0.75rem 0 0.55rem;
      cursor: grab;
      touch-action: none;
      background: transparent;
      border: 0;
    }

    .panel-grip span {
      display: block;
      width: 2.6rem;
      height: 0.25rem;
      background: rgb(64 19 6 / 22%);
      border-radius: var(--radius-pill);
    }

    .map-panel.is-dragging {
      transition: none;
    }

    .map-panel.is-dragging .panel-grip {
      cursor: grabbing;
    }

    .locate-button {
      z-index: 920;
      inset-block-end: calc(
        var(--map-control-bottom) + var(--map-zoom-height) +
          var(--map-control-gap)
      );
      inset-inline-end: 0.9rem;
    }

    .map-stage :global(.leaflet-bottom.leaflet-right) {
      z-index: 910;
      margin-block-end: var(--map-control-bottom);
      margin-inline-end: 0.25rem;
    }
  }
</style>
