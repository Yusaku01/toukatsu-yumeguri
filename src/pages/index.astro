---
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCities, getSpas } from "../lib/spas";

const spas = await getSpas();
const cities = getCities(spas);
---

<BaseLayout bodyClass="map-page">
  <fragment slot="head">
    <link rel="preconnect" href="https://tiles.stadiamaps.com" />
    <link
      rel="preload"
      href="https://tiles.stadiamaps.com/tiles/alidade_smooth/9/455/200.png"
      as="image"
      type="image/png"
      fetchpriority="high"
      media="(max-width: 900px)"
    />
    <link
      rel="preload"
      href="https://tiles.stadiamaps.com/tiles/alidade_smooth/9/455/202.png"
      as="image"
      type="image/png"
      fetchpriority="high"
      media="(max-width: 900px)"
    />
  </fragment>
  <SiteHeader current="map" />
  <main
    id="content"
    class="map-shell"
    tabindex="-1"
    transition:name="page-content"
  >
    <section class="map-stage" aria-label="温浴施設の地図">
      <div id="map" class="map-canvas" data-spas={JSON.stringify(spas)}></div>
      <search class="map-search" aria-label="温浴施設の絞り込み">
        <div class="city-filter" aria-label="市区町村で絞り込み">
          <button type="button" data-city-filter="all" aria-pressed="true"
            >すべて</button
          >
          {
            cities.map((city) => (
              <button
                type="button"
                data-city-filter={city}
                aria-pressed="false"
              >
                {city}
              </button>
            ))
          }
        </div>
      </search>
    </section>
    <aside
      id="map-panel"
      class="map-panel"
      aria-label="選択した温浴施設"
      aria-expanded="false"
      aria-hidden="true"
      data-map-panel
    >
      <button
        class="panel-grip"
        type="button"
        data-panel-grip
        aria-controls="map-panel"
        aria-label="施設一覧パネルを広げる"
      >
        <span aria-hidden="true"></span>
      </button>
      <button
        class="panel-close"
        type="button"
        data-panel-close
        aria-label="施設パネルを閉じる"
      >
        <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M6 6l12 12M18 6L6 18"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </button>
      <div class="spa-list" data-spa-list></div>
    </aside>
  </main>
  <script>
    import "../scripts/map";
  </script>
  <script>
    const mobileQuery = window.matchMedia("(max-width: 900px)");

    const collapsedHeight = 30;
    const expandedHeight = 62;
    const minimumHeight = 24;
    const expandedSnapThreshold = (collapsedHeight + expandedHeight) / 2;

    const initPanelSheet = () => {
      const panel = document.querySelector<HTMLElement>(".map-panel");
      const shell = document.querySelector<HTMLElement>(".map-shell");
      const grip =
        document.querySelector<HTMLButtonElement>("[data-panel-grip]");
      const closeButton =
        document.querySelector<HTMLButtonElement>("[data-panel-close]");
      if (!panel || !shell || !grip || panel.dataset.sheetReady === "true") {
        return;
      }

      panel.dataset.sheetReady = "true";

      let panelHeight = collapsedHeight;
      let startY = 0;
      let startHeight = collapsedHeight;
      let ignoreNextClick = false;

      const updatePanelHeight = (clientY: number) => {
        const delta = startY - clientY;
        if (Math.abs(delta) > 6) {
          ignoreNextClick = true;
        }

        setPanelHeight(startHeight + (delta / window.innerHeight) * 100);
      };

      const setPanelHeight = (height: number) => {
        const clampedHeight = Math.min(
          expandedHeight,
          Math.max(minimumHeight, height),
        );

        panelHeight = clampedHeight;
        shell.style.setProperty("--mobile-panel-height", `${clampedHeight}svh`);
        panel.setAttribute(
          "aria-expanded",
          clampedHeight > collapsedHeight ? "true" : "false",
        );
        grip.setAttribute(
          "aria-label",
          clampedHeight > collapsedHeight
            ? "施設一覧パネルをたたむ"
            : "施設一覧パネルを広げる",
        );
      };

      const openPanel = () => {
        setPanelHeight(collapsedHeight);
      };

      const snapPanelHeight = () => {
        setPanelHeight(
          panelHeight >= expandedSnapThreshold
            ? expandedHeight
            : collapsedHeight,
        );
        panel.classList.remove("is-dragging");
      };

      const handlePointerMove = (event: PointerEvent) => {
        if (!mobileQuery.matches) return;
        updatePanelHeight(event.clientY);
      };

      const handleTouchMove = (event: TouchEvent) => {
        if (!mobileQuery.matches || event.touches.length === 0) return;
        if (event.cancelable) event.preventDefault();
        updatePanelHeight(event.touches[0].clientY);
      };

      const startDrag = (clientY: number) => {
        startY = clientY;
        startHeight = panelHeight;
        panel.classList.add("is-dragging");
      };

      const stopDrag = () => {
        window.removeEventListener("pointermove", handlePointerMove);
        window.removeEventListener("touchmove", handleTouchMove);
        snapPanelHeight();
      };

      grip.addEventListener("pointerdown", (event) => {
        if (!mobileQuery.matches || !panel.classList.contains("is-open")) {
          return;
        }
        if (event.pointerType === "touch") return;

        startDrag(event.clientY);
        grip.setPointerCapture(event.pointerId);

        window.addEventListener("pointermove", handlePointerMove);
        window.addEventListener("pointerup", stopDrag, { once: true });
        window.addEventListener("pointercancel", stopDrag, { once: true });
      });

      grip.addEventListener(
        "touchstart",
        (event) => {
          if (!mobileQuery.matches || event.touches.length === 0) return;
          if (!panel.classList.contains("is-open")) return;
          if (event.cancelable) event.preventDefault();

          startDrag(event.touches[0].clientY);
          window.addEventListener("touchmove", handleTouchMove, {
            passive: false,
          });
          window.addEventListener("touchend", stopDrag, { once: true });
          window.addEventListener("touchcancel", stopDrag, { once: true });
        },
        { passive: false },
      );

      grip.addEventListener("click", () => {
        if (!mobileQuery.matches || !panel.classList.contains("is-open")) {
          return;
        }

        if (ignoreNextClick) {
          ignoreNextClick = false;
          return;
        }

        setPanelHeight(
          panelHeight > collapsedHeight ? collapsedHeight : expandedHeight,
        );
      });

      closeButton?.addEventListener("click", () => {
        panel.dispatchEvent(new CustomEvent("spa-panel-close"));
      });

      mobileQuery.addEventListener("change", () => {
        if (mobileQuery.matches) {
          if (panel.classList.contains("is-open")) {
            openPanel();
          }
          return;
        }

        shell.style.removeProperty("--mobile-panel-height");
        panel.classList.remove("is-dragging");
        panel.setAttribute("aria-expanded", "false");
      });

      panel.addEventListener("spa-panel-open", openPanel);
    };

    document.addEventListener("astro:page-load", initPanelSheet);
    initPanelSheet();
  </script>
</BaseLayout>

<style>
  .map-shell {
    --mobile-panel-height: 30svh;
    --mobile-panel-closed-height: 2.75rem;
    --map-control-bottom: calc(1rem + var(--safe-bottom));
    --map-control-gap: 2rem;
    --map-zoom-height: 4.25rem;
    --map-transition-duration: 0.3s;
    --map-transition-easing: cubic-bezier(0.2, 0, 0, 1);

    position: relative;
    display: grid;
    grid-template-columns: minmax(22rem, 28rem) 1fr;
    width: 100vw;
    height: 100vh;
    min-height: 560px;
  }

  .map-stage {
    position: relative;
    grid-column: 1 / -1;
    grid-row: 1;
    min-width: 0;
    min-height: 0;
  }

  .map-canvas {
    width: 100%;
    height: 100%;
    background:
      linear-gradient(120deg, rgb(112 200 215 / 16%), transparent 48%), #dce8e4;
  }

  .map-panel {
    position: relative;
    z-index: 500;
    grid-column: 1;
    grid-row: 1;
    align-self: start;
    width: min(25.5rem, calc(100vw - 1.5rem));
    max-height: calc(100vh - 6.35rem);
    margin: 5.6rem 0 0 0.75rem;
    overflow: hidden;
    background: rgb(255 250 244 / 98%);
    border: 1px solid rgb(64 19 6 / 12%);
    border-radius: var(--radius-card);
    box-shadow: 0 2px 8px rgb(45 22 14 / 16%);
    opacity: 0;
    pointer-events: none;
    transform: translateX(-100%);
    transition:
      opacity var(--map-transition-duration) var(--map-transition-easing),
      transform var(--map-transition-duration) var(--map-transition-easing);
  }

  .map-panel.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .map-panel:not(.is-open) .panel-close {
    display: none;
  }

  .panel-close {
    position: absolute;
    z-index: 2;
    inset-block-start: 0.65rem;
    inset-inline-end: 0.65rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.45rem;
    height: 2.45rem;
    color: var(--color-brand-dark);
    background: rgb(255 255 255 / 88%);
    border: 1px solid rgb(64 19 6 / 12%);
    border-radius: 999px;
    box-shadow: 0 1px 4px rgb(45 22 14 / 14%);
    scale: 1;
    translate: 0 0;
    transition-duration: var(--map-transition-duration);
    transition-property:
      background-color, border-color, box-shadow, color, scale, translate;
    transition-timing-function: var(--map-transition-easing);
  }

  .spa-list {
    display: grid;
    max-height: calc(100vh - 6.35rem);
    padding: 0;
    overflow: auto;
    overscroll-behavior: contain;
    scrollbar-gutter: stable;
  }

  :global(.map-panel .spa-card) {
    display: grid;
    gap: 1.15rem;
    align-content: start;
    padding: 3.55rem 1.25rem 1.25rem;
    text-align: start;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
    transition:
      opacity var(--map-transition-duration) var(--map-transition-easing),
      transform var(--map-transition-duration) var(--map-transition-easing);
  }

  @starting-style {
    :global(.map-panel .spa-card) {
      opacity: 0;
      transform: translateY(0.5rem);
    }
  }

  :global(.map-panel .spa-card-main) {
    min-width: 0;
  }

  :global(.map-panel .spa-meta) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    margin: 0 0 0.75rem;
    font-size: 0.76rem;
    font-weight: 800;
    color: var(--color-brand);
  }

  :global(.map-panel .spa-meta span) {
    display: inline-flex;
    align-items: center;
    min-height: 1.6rem;
    padding: 0.16rem 0.52rem;
    background: #fff3ea;
    border-radius: var(--radius-pill);
  }

  :global(.map-panel .spa-card h2) {
    margin: 0;
    font-size: 1.42rem;
    line-height: 1.32;
    letter-spacing: 0;
  }

  :global(.map-panel .spa-summary) {
    margin: 0.75rem 0 0;
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  :global(.map-panel .spa-detail-list) {
    display: grid;
    gap: 0;
    margin-block-start: 1.05rem;
    border-block: 1px solid var(--color-border);
  }

  :global(.map-panel .spa-detail-row) {
    display: grid;
    grid-template-columns: 4.25rem minmax(0, 1fr);
    gap: 0.8rem;
    align-items: center;
    padding-block: 0.9rem;
  }

  :global(.map-panel .spa-detail-row:not(:last-child)) {
    border-bottom: 1px solid var(--color-border);
  }

  :global(.map-panel .spa-detail-label) {
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.35;
    color: var(--color-muted);
  }

  :global(.map-panel .spa-card address) {
    margin: 0;
    font-style: normal;
    line-height: 1.65;
    color: var(--color-text);
  }

  :global(.map-panel .spa-summary + .spa-detail-list) {
    margin-block-start: 1.15rem;
  }

  :global(.map-panel .tag-list) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  :global(.map-panel .tag-list li) {
    padding: 0.24rem 0.58rem;
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--color-brand-dark);
    background: #fff3ea;
    border: 1px solid rgb(184 42 11 / 14%);
    border-radius: var(--radius-pill);
  }

  :global(.map-panel .spa-actions) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
    padding-block-start: 0.15rem;
  }

  :global(.map-panel .external-link) {
    justify-content: center;
    min-height: 2.75rem;
    text-align: center;
    scale: 1;
    translate: 0 0;
    transition-duration: var(--map-transition-duration);
    transition-property:
      background-color, border-color, box-shadow, color, scale, translate;
    transition-timing-function: var(--map-transition-easing);
  }

  .panel-grip {
    display: none;
  }

  .map-search {
    position: fixed;
    z-index: 700;
    inset-block-start: 0.75rem;
    inset-inline: 19rem 8rem;
    pointer-events: none;
  }

  .map-shell.is-panel-open .map-search {
    inset-inline-start: 27.5rem;
  }

  .city-filter {
    display: flex;
    gap: 0.45rem;
    align-items: center;
    min-height: 3rem;
    padding-block: 0.15rem;
    overflow-x: auto;
    pointer-events: auto;
    scrollbar-width: none;
  }

  .city-filter::-webkit-scrollbar {
    display: none;
  }

  .city-filter button {
    display: inline-flex;
    gap: 0.35rem;
    align-items: center;
    min-height: 2.7rem;
    padding: 0.55rem 0.85rem;
    font-weight: 800;
    color: var(--color-brand-dark);
    white-space: nowrap;
    background: rgb(255 250 244 / 94%);
    border: 1px solid rgb(64 19 6 / 12%);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-chip);
    backdrop-filter: blur(12px);
  }

  .city-filter button {
    min-height: 2.15rem;
    padding: 0.4rem 0.68rem;
    font-size: 0.9rem;
    scale: 1;
    translate: 0 0;
    transition-duration: var(--map-transition-duration);
    transition-property:
      background-color, border-color, box-shadow, color, scale, translate;
    transition-timing-function: var(--map-transition-easing);
  }

  .city-filter button[aria-pressed="true"] {
    color: var(--color-surface-strong);
    background: var(--color-brand);
    border-color: var(--color-brand);
  }

  .map-stage :global(.leaflet-bottom.leaflet-right) {
    margin-block-end: var(--map-control-bottom);
    margin-inline-end: 0.6rem;
  }

  .map-stage :global(.leaflet-control-locate a) {
    display: grid;
    place-items: center;
    color: #000;
  }

  .map-stage :global(.leaflet-control-locate a[aria-disabled="true"]) {
    cursor: progress;
    opacity: 0.72;
  }

  .map-stage :global(.leaflet-control-locate svg) {
    width: 18px;
    height: 18px;
  }

  .panel-close:active,
  :global(.map-panel .external-link:active),
  .city-filter button:active {
    scale: 0.98;
    translate: 0 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .panel-close:hover {
      color: var(--color-surface-strong);
      background: var(--color-brand);
      border-color: var(--color-brand);
      box-shadow: 0 8px 20px rgb(45 22 14 / 20%);
      scale: 1.06;
      translate: 0 -1px;
    }

    :global(.map-panel .external-link:hover) {
      background: rgb(255 255 255 / 86%);
      border-color: rgb(184 42 11 / 30%);
      box-shadow: 0 8px 20px rgb(45 22 14 / 14%);
      scale: 1.02;
      translate: 0 -1px;
    }

    :global(.map-panel .primary-link:hover) {
      background: var(--color-brand-dark);
      border-color: var(--color-brand-dark);
    }

    .city-filter button:hover:not([aria-pressed="true"]) {
      color: var(--color-surface-strong);
      background: var(--color-brand);
      border-color: var(--color-brand);
      box-shadow: 0 8px 20px rgb(45 22 14 / 16%);
      scale: 1.03;
      translate: 0 -2px;
    }
  }

  @media (max-width: 900px) {
    .map-shell {
      --map-control-bottom: calc(
        var(--mobile-panel-closed-height) + 0.7rem + var(--safe-bottom)
      );

      display: block;
      min-height: 100svh;
    }

    .map-stage,
    .map-canvas {
      height: 100svh;
    }

    .map-search {
      inset-block-start: 4.85rem;
      inset-inline: 0.75rem 0;
    }

    .map-shell.is-panel-open .map-search {
      inset-inline: 0.75rem 0;
    }

    .map-panel {
      position: fixed;
      z-index: 900;
      inset-inline: 0;
      inset-block-end: var(--safe-bottom);
      width: auto;
      height: var(--mobile-panel-closed-height);
      max-height: calc(86svh - var(--safe-bottom));
      margin: 0;
      border-inline: 0;
      border-end-end-radius: 0;
      border-end-start-radius: 0;
      box-shadow: 0 -2px 12px rgb(45 22 14 / 16%);
      transition:
        height var(--map-transition-duration) var(--map-transition-easing),
        max-height var(--map-transition-duration) var(--map-transition-easing),
        transform var(--map-transition-duration) var(--map-transition-easing);
      opacity: 1;
      pointer-events: auto;
      transform: translateY(calc(100% - var(--mobile-panel-closed-height)));
    }

    .map-panel.is-open {
      height: auto;
      max-height: var(--mobile-panel-height);
      transform: translateY(0);
    }

    .map-panel:not(.is-open) .spa-list {
      display: none;
    }

    .spa-list {
      max-height: calc(var(--mobile-panel-height) - 3.25rem);
      overscroll-behavior: contain;
      scrollbar-gutter: stable;
    }

    :global(.map-panel .spa-card) {
      min-height: auto;
      margin-block-end: 20px;
      padding: 0 1rem 1rem;
    }

    :global(.map-panel .spa-card h2) {
      padding-inline-end: 2.4rem;
      font-size: 1.22rem;
    }

    :global(.map-panel .spa-summary) {
      font-size: 0.94rem;
      line-height: 1.62;
    }

    :global(.map-panel .spa-detail-row) {
      grid-template-columns: 3.75rem minmax(0, 1fr);
      gap: 0.65rem;
      padding-block: 0.75rem;
    }

    .panel-close {
      inset-block-start: 2.85rem;
      inset-inline-end: 0.75rem;
      width: 2.25rem;
      height: 2.25rem;
    }

    .panel-grip {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      min-height: 2.5rem;
      padding: 0.75rem 0 0.55rem;
      cursor: grab;
      touch-action: none;
      background: transparent;
      border: 0;
    }

    .panel-grip span {
      display: block;
      width: 2.6rem;
      height: 0.25rem;
      background: rgb(64 19 6 / 22%);
      border-radius: var(--radius-pill);
    }

    .map-panel.is-dragging {
      transition: none;
    }

    .map-panel.is-dragging .panel-grip {
      cursor: grabbing;
    }

    .map-stage :global(.leaflet-bottom.leaflet-right) {
      z-index: 800;
      margin-block-end: var(--map-control-bottom);
      margin-inline-end: 0.25rem;
    }
  }
</style>
