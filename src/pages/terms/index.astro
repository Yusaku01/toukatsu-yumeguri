---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "利用規約";
const pageDescription =
  "東葛湯めぐりマップの掲載情報、現在地、アクセス解析、連絡先・貢献についてまとめています。";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  bodyClass="prototype-terms-page"
  canonicalPath="/terms/"
>
  <main id="content" class="prototype-terms" tabindex="-1">
    <header class="prototype-header" aria-label="サイトナビゲーション">
      <a
        class="prototype-brand"
        href="/"
        aria-label="東葛湯めぐりマップ"
        data-astro-reload
      >
        <span class="prototype-brand-pin-shell" aria-hidden="true">
          <span class="prototype-brand-pin"></span>
        </span>
        <span>東葛湯めぐりマップ</span>
      </a>
      <details class="prototype-menu">
        <summary>
          <span class="prototype-icon prototype-icon--menu" aria-hidden="true"
          ></span>
          <span>MENU</span>
        </summary>
        <nav aria-label="サイトメニュー">
          <a href="/" data-astro-reload>地図</a>
          <a href="/list/">一覧</a>
          <a href="/my/">マイページ</a>
          <a href="/terms/" aria-current="page">利用規約</a>
        </nav>
      </details>
    </header>

    <article class="prototype-article">
      <header class="prototype-page-head">
        <h1>利用規約</h1>
      </header>

      <div class="prototype-section-list">
        <section class="prototype-section">
          <span class="prototype-section-number" aria-hidden="true">01</span>
          <div>
            <h2>掲載情報</h2>
            <p>
              掲載している施設情報は、公式サイトや公開情報をもとに確認しています。営業時間、料金、休館日などは変更されることがあるため、訪問前に各施設の公式サイトをご確認ください。
            </p>
          </div>
        </section>

        <section class="prototype-section">
          <span class="prototype-section-number" aria-hidden="true">02</span>
          <div>
            <h2>現在地</h2>
            <p>
              現在地機能は、ブラウザで許可された場合にだけ端末内で距離表示と並び替えに使います。このサイトは現在地を保存しません。
            </p>
          </div>
        </section>

        <section class="prototype-section">
          <span class="prototype-section-number" aria-hidden="true">03</span>
          <div>
            <h2>湯めぐり記録</h2>
            <p>
              記録はこの端末のブラウザ内に保存されます。行った施設、気になる施設、スタンプ、進捗はマイページから削除でき、ブラウザデータを削除した場合も破棄されます。
            </p>
          </div>
        </section>

        <section class="prototype-section">
          <span class="prototype-section-number" aria-hidden="true">04</span>
          <div>
            <h2>アクセス解析</h2>
            <p>
              Cloudflare Web
              Analyticsを利用しております。Cookieを使わず、個人を直接識別する情報の収集を目的としません。
            </p>
          </div>
        </section>

        <section class="prototype-section">
          <span class="prototype-section-number" aria-hidden="true">05</span>
          <div>
            <h2>連絡先・貢献</h2>
            <p>
              掲載内容の追加・修正提案は、GitHubリポジトリまたは作者のXアカウントからお願いします。
            </p>
            <p class="prototype-link-row">
              <a
                class="prototype-social-link prototype-social-link--primary"
                href="https://github.com/Yusaku01/toukatsu-yumeguri"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHubリポジトリを開く"
              >
                <img src="/github-mark.svg" alt="" width="18" height="18" />
                <span>GitHub</span>
              </a>
              <a
                class="prototype-social-link"
                href="https://x.com/sakku_04"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Xアカウントを開く"
              >
                <img src="/x-logo.svg" alt="" width="18" height="18" />
              </a>
            </p>
          </div>
        </section>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  :global(body.prototype-terms-page) {
    background: #fffaf7;
  }

  .prototype-terms {
    --prototype-ink: #3e2013;
    --prototype-muted: #7d6559;
    --prototype-line: rgb(80 45 28 / 13%);
    --prototype-paper: rgb(255 251 246 / 96%);
    --prototype-paper-solid: #fffaf7;
    --prototype-brand: #c82006;
    --prototype-brand-pressed: #a91b05;
    --prototype-brand-dark: #451406;
    --prototype-surface-hover: #fff6ef;
    --prototype-surface-pressed: #f5e8dd;
    --prototype-tag-surface: #fff3ea;
    --prototype-ease: cubic-bezier(0.2, 0, 0, 1);
    inline-size: min(100dvw, 520px);
    min-block-size: 100svh;
    padding: max(1.35rem, env(safe-area-inset-top)) 0.86rem 2.4rem;
    margin-inline: auto;
    color: var(--prototype-ink);
    background: #fffaf7;
  }

  .prototype-header {
    position: relative;
    z-index: 10;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
    margin-block-end: 2rem;
  }

  .prototype-brand,
  .prototype-menu summary {
    min-block-size: 2.7rem;
    border-radius: 999px;
    backdrop-filter: blur(14px);
  }

  .prototype-brand {
    display: inline-flex;
    gap: 0.52rem;
    align-items: center;
    max-inline-size: calc(100% - 6.6rem);
    padding: 0.48rem 0.82rem 0.48rem 0.54rem;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.1;
    color: var(--prototype-ink);
    text-decoration: none;
    background: var(--prototype-paper);
    border: 1px solid var(--prototype-line);
    transition:
      background-color 180ms var(--prototype-ease),
      border-color 180ms var(--prototype-ease),
      transform 180ms var(--prototype-ease);
  }

  .prototype-brand:hover {
    background: var(--prototype-surface-hover);
    border-color: rgb(80 45 28 / 22%);
    transform: translateY(-1px);
  }

  .prototype-brand:active {
    background: var(--prototype-surface-pressed);
    border-color: rgb(80 45 28 / 26%);
    transform: translateY(1px);
  }

  .prototype-brand-pin-shell {
    display: inline-grid;
    flex: 0 0 auto;
    inline-size: 1.74rem;
    block-size: 1.74rem;
    place-items: center;
  }

  .prototype-brand-pin {
    display: block;
    color: var(--prototype-brand);
    inline-size: 1.15rem;
    block-size: 1.15rem;
    background: currentColor;
    -webkit-mask: url("/onsen.svg") center / contain no-repeat;
    mask: url("/onsen.svg") center / contain no-repeat;
  }

  .prototype-brand span:last-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .prototype-menu {
    position: relative;
  }

  .prototype-menu summary {
    display: inline-flex;
    gap: 0.42rem;
    align-items: center;
    padding: 0.58rem 0.76rem;
    font-size: 0.95rem;
    font-weight: 850;
    line-height: 1;
    color: var(--prototype-ink);
    list-style: none;
    cursor: pointer;
    background: var(--prototype-paper);
    border: 1px solid var(--prototype-line);
    transition:
      background-color 180ms var(--prototype-ease),
      border-color 180ms var(--prototype-ease),
      transform 180ms var(--prototype-ease);
  }

  .prototype-menu summary:hover,
  .prototype-menu[open] summary {
    background: var(--prototype-surface-hover);
    border-color: rgb(80 45 28 / 22%);
    transform: translateY(-1px);
  }

  .prototype-menu summary:active {
    background: var(--prototype-surface-pressed);
    border-color: rgb(80 45 28 / 26%);
    transform: translateY(1px);
  }

  .prototype-menu summary::-webkit-details-marker {
    display: none;
  }

  .prototype-menu nav {
    position: absolute;
    inset-block-start: calc(100% + 0.5rem);
    inset-inline-end: 0;
    z-index: 20;
    display: grid;
    inline-size: max-content;
    min-inline-size: 8.5rem;
    padding: 0.45rem;
    background: var(--prototype-paper-solid);
    border: 1px solid var(--prototype-line);
    border-radius: 0.85rem;
  }

  .prototype-menu[open] nav {
    animation: prototype-menu-reveal 180ms var(--prototype-ease) both;
  }

  .prototype-menu a {
    padding: 0.55rem 0.7rem;
    font-weight: 800;
    color: inherit;
    text-decoration: none;
    border-radius: 0.55rem;
  }

  .prototype-menu a:hover,
  .prototype-menu a[aria-current="page"] {
    background: var(--prototype-surface-pressed);
  }

  @keyframes prototype-menu-reveal {
    from {
      opacity: 0;
      transform: translateY(-0.28rem);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .prototype-article {
    display: grid;
    gap: 1.05rem;
  }

  .prototype-page-head {
    display: grid;
    gap: 0.38rem;
  }

  .prototype-page-head h1,
  .prototype-section h2,
  .prototype-section p {
    margin: 0;
  }

  .prototype-page-head h1 {
    font-size: clamp(1.36rem, 6.2vw, 1.72rem);
    font-weight: 900;
    line-height: 1.22;
    letter-spacing: 0;
  }

  .prototype-section-list {
    display: grid;
    --prototype-dot-divider: radial-gradient(
      circle,
      rgb(80 45 28 / 18%) 0 1.2px,
      transparent 1.35px
    );
    background:
      var(--prototype-dot-divider) left top / 0.48rem 0.25rem repeat-x,
      var(--prototype-dot-divider) left bottom / 0.48rem 0.25rem repeat-x;
  }

  .prototype-section {
    position: relative;
    display: grid;
    grid-template-columns: 2.55rem minmax(0, 1fr);
    gap: 0.72rem;
    padding-block: 1.05rem;
  }

  .prototype-section:not(:last-child)::after {
    position: absolute;
    inset-inline: 0;
    inset-block-end: -0.125rem;
    display: block;
    block-size: 0.25rem;
    pointer-events: none;
    content: "";
    background: var(--prototype-dot-divider) left center / 0.48rem 0.25rem
      repeat-x;
  }

  .prototype-section-number {
    padding-inline-start: 0.8rem;
    font-size: 1.2rem;
    font-weight: 900;
    line-height: 1;
    color: var(--prototype-brand-dark);
  }

  .prototype-section h2 {
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.45;
    letter-spacing: 0;
  }

  .prototype-section p {
    margin-block-start: 0.36rem;
    font-size: 0.92rem;
    line-height: 1.85;
    color: var(--prototype-muted);
  }

  .prototype-link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .prototype-social-link {
    display: inline-flex;
    gap: 0.42rem;
    align-items: center;
    justify-content: center;
    min-block-size: 2.7rem;
    padding: 0.5rem 0.86rem;
    font-size: 0.9rem;
    font-weight: 850;
    line-height: 1;
    color: var(--prototype-ink);
    text-decoration: none;
    background: var(--prototype-tag-surface);
    border: 1px solid rgb(80 45 28 / 10%);
    border-radius: 999px;
  }

  .prototype-social-link--primary {
    color: #fff;
    background: var(--prototype-brand);
    border-color: var(--prototype-brand);
  }

  .prototype-social-link img {
    inline-size: 1.12rem;
    block-size: 1.12rem;
    flex: 0 0 auto;
  }

  .prototype-social-link--primary img {
    filter: brightness(0) invert(1);
  }

  .prototype-icon {
    display: inline-block;
    inline-size: 1.02rem;
    block-size: 1.02rem;
    flex: 0 0 auto;
    background: currentColor;
    -webkit-mask: var(--prototype-icon-url) center / contain no-repeat;
    mask: var(--prototype-icon-url) center / contain no-repeat;
  }

  .prototype-icon--menu {
    --prototype-icon-url: url("https://unpkg.com/lucide-static@0.468.0/icons/menu.svg");
  }

  @media (min-width: 521px) {
    .prototype-terms {
      border-inline: 1px solid rgb(80 45 28 / 10%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prototype-brand,
    .prototype-menu summary {
      transition-duration: 0.01ms;
    }

    .prototype-menu[open] nav {
      animation-duration: 0.01ms;
    }
  }
</style>
