---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import StampPressOverlay from "../components/StampPressOverlay.astro";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
  canonicalPath?: string;
  noindex?: boolean;
  jsonLd?: unknown;
};

const siteName = "東葛湯めぐりマップ";
const description =
  Astro.props.description ??
  "東葛地域で、今日行きたい温浴施設を地図から探せる湯めぐりマップです。";
const title = Astro.props.title
  ? `${Astro.props.title} | ${siteName}`
  : siteName;
const bodyClass = Astro.props.bodyClass ?? "";
const analyticsToken =
  import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN ||
  "3940c661deaf4736a407f50c4a35c0e5";
const analyticsConfig = JSON.stringify({ token: analyticsToken });
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? Astro.site?.toString();
const ogImage = siteUrl ? new URL("/ogp.png", siteUrl).toString() : "/ogp.png";
const ogUrl = siteUrl
  ? new URL(Astro.url.pathname, siteUrl).toString()
  : Astro.url.pathname;
const canonicalUrl = siteUrl
  ? new URL(Astro.props.canonicalPath ?? Astro.url.pathname, siteUrl).toString()
  : undefined;
const robotsContent = Astro.props.noindex
  ? "noindex, nofollow"
  : "index, follow";
const jsonLd = Astro.props.jsonLd
  ? JSON.stringify(Astro.props.jsonLd)
  : undefined;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-48.png" type="image/png" sizes="48x48" />
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <Font cssVariable="--font-sans" />
    {
      jsonLd && (
        <script type="application/ld+json" is:inline set:html={jsonLd} />
      )
    }
    <ClientRouter fallback="animate" />
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <a href="#content" class="skip-link">本文へ移動</a>
    <slot />
    <StampPressOverlay />
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon={analyticsConfig}></script>
  </body>
</html>
